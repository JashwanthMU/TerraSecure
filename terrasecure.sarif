          ],
          "properties": {
            "resource": "aws_s3_bucket.customer_data",
            "severity": "medium",
            "ml_risk_score": 0.947,
            "ml_confidence": 0.947
          },
          "fixes": [
            {
              "description": {
                "text": "Recommended fix"
